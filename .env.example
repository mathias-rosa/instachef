
# AI 
AI_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_API_KEY=your-gemini-key # If using Gemini API
OPENAI_API_KEY=your-openai-key # If using OpenAI API

# Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_AUTHORIZED_USER_IDS=123456789, 987654321, ...

# Storage backend
RECIPE_REPOSITORY_BACKEND=supabase 
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Optional: If using local JSON storage, specify the file path
# RECIPE_REPOSITORY_BACKEND=local_json
# LOCAL_JSON_FILE_PATH=recipes.json

# Optional: If using MongoDB storage, configure the connection and target collection
# RECIPE_REPOSITORY_BACKEND=mongodb
# MONGODB_URI=mongodb://localhost:27018
# MONGODB_DATABASE=instachef
# MONGODB_COLLECTION=recipes